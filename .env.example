# Copy this file to .env and fill in your keys
# Never commit .env to git

# ── Weather APIs (India-optimised chain) ─────────────────────────────────
# Primary: WeatherAPI — best Indian town/district names (Warangal, Nizamabad, etc.)
# Free tier: 1M calls/month — https://www.weatherapi.com
WEATHERAPI_KEY=your_weatherapi_key_here

# Fallback: Open-Meteo — FREE, no key, coordinate-based weather across India
# Geocoding: https://geocoding-api.open-meteo.com (also free, country=IN filter)

# Legacy fallback: OpenWeatherMap — weak geocoding for smaller Indian cities
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# Geocoding fallback: OpenStreetMap Nominatim (free, no key, countrycodes=in)

# ── Plant Disease APIs ────────────────────────────────────────────────────
# Plant.id — https://plant.id (free: 100 requests/month)
PLANTID_API_KEY=your_plantid_api_key_here

# ── Notification APIs ─────────────────────────────────────────────────────
# Twilio SMS — https://console.twilio.com (free trial available)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── AI/NLP APIs ───────────────────────────────────────────────────────────
# OpenAI — https://platform.openai.com/api-keys
# Used for: AI chatbot + multilingual translation
OPENAI_API_KEY=your_openai_api_key_here

# ── App settings ──────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
